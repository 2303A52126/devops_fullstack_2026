# ============================================
# AI Study Planner - Environment Variables
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/study_planner?retryWrites=true&w=majority

# Session Secret (use a long random string in production)
SESSION_SECRET=your_super_secret_session_key_change_this_in_production_min_32_chars

# Session Configuration
SESSION_MAX_AGE=86400000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=public/uploads

# App URL (for production)
APP_URL=http://localhost:3000

# Admin Default Credentials (only for first-time setup)
ADMIN_EMAIL=admin@studyplanner.com
ADMIN_PASSWORD=Admin@123456

# Cloud Configuration (Optional - for deployment)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
