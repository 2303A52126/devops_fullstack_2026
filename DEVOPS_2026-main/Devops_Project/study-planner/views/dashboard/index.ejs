<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
</head>
<body>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Dashboard' }) %>
    <%- include('../partials/flash') %>

    <div class="page-content">
      <!-- Header -->
      <div class="page-header">
        <div class="page-header-left">
          <h1 class="page-title">
            Good <%= new Date().getHours() < 12 ? 'morning' : new Date().getHours() < 17 ? 'afternoon' : 'evening' %>,
            <%= currentUser.name.split(' ')[0] %> 👋
          </h1>
          <p class="page-subtitle">Here's what your study plan looks like today.</p>
        </div>
        <a href="/planner/ai-schedule" class="btn btn-primary">
          ✦ View AI Schedule
        </a>
      </div>

      <!-- Stats Grid -->
      <div class="stats-grid">
        <div class="stat-card accent">
          <div class="stat-icon">📚</div>
          <div class="stat-value"><%= stats.total %></div>
          <div class="stat-label">Total Tasks</div>
        </div>
        <div class="stat-card green">
          <div class="stat-icon">✓</div>
          <div class="stat-value"><%= stats.completed %></div>
          <div class="stat-label">Completed</div>
        </div>
        <div class="stat-card cyan">
          <div class="stat-icon">⟳</div>
          <div class="stat-value"><%= stats.inProgress %></div>
          <div class="stat-label">In Progress</div>
        </div>
        <div class="stat-card amber">
          <div class="stat-icon">⏳</div>
          <div class="stat-value"><%= stats.pending %></div>
          <div class="stat-label">Pending</div>
        </div>
        <div class="stat-card red">
          <div class="stat-icon">⚠</div>
          <div class="stat-value"><%= stats.overdue %></div>
          <div class="stat-label">Overdue</div>
        </div>
        <div class="stat-card accent" style="background: linear-gradient(135deg, rgba(108,99,255,0.15), rgba(0,212,255,0.08));">
          <div style="display:flex;align-items:center;justify-content:space-between;height:100%;">
            <div>
              <div class="stat-value"><%= stats.completionRate %>%</div>
              <div class="stat-label">Completion Rate</div>
            </div>
            <svg width="56" height="56" class="progress-ring">
              <circle class="progress-ring-bg" cx="28" cy="28" r="22" stroke-width="4"/>
              <circle class="progress-ring-fill" cx="28" cy="28" r="22" stroke-width="4"
                data-percent="<%= stats.completionRate %>"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- AI Recommendation -->
      <% if (recommendation) { %>
      <div class="ai-box mb-16">
        <div class="ai-box-label">✦ AI Recommendation</div>
        <div class="ai-box-title"><%= recommendation.task.topic %></div>
        <p class="ai-box-reason"><%= recommendation.reason %></p>
        <div class="d-flex gap-8 align-center" style="flex-wrap:wrap;">
          <span class="ai-score">AI Score: <%= recommendation.task.aiScore %></span>
          <span class="badge badge-<%= recommendation.task.priority %>"><%= recommendation.task.priority %></span>
          <span class="badge badge-<%= recommendation.task.difficulty || 'medium' %>"><%= recommendation.task.difficulty || 'medium' %></span>
          <span class="text-muted">💡 <%= recommendation.suggestion %></span>
          <a href="/planner/<%= recommendation.task._id %>" class="btn btn-sm btn-primary" style="margin-left:auto;">
            Start Studying →
          </a>
        </div>
      </div>
      <% } %>

      <!-- Charts row -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
        <!-- Bar Chart -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">📊 Weekly Study Hours</div>
          </div>
          <div class="card-body">
            <div class="chart-container" style="height:220px;">
              <canvas id="barChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Pie Chart -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">🎯 Subject Distribution</div>
          </div>
          <div class="card-body">
            <div class="chart-container" style="height:220px;">
              <canvas id="pieChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom row -->
      <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:20px;margin-bottom:24px;">
        <!-- Recent Tasks -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">📝 Recent Tasks</div>
            <a href="/planner" class="btn btn-ghost btn-sm">View all →</a>
          </div>
          <div class="card-body" style="padding-top:8px;padding-bottom:8px;">
            <% if (recentTasks.length === 0) { %>
              <div class="empty-state" style="padding:30px 0;">
                <div class="empty-icon">📭</div>
                <div class="empty-title">No tasks yet</div>
                <a href="/planner/create" class="btn btn-primary btn-sm">Add your first task</a>
              </div>
            <% } else { %>
              <% recentTasks.forEach(task => { %>
              <div class="task-row">
                <div class="task-dot task-dot-<%= task.status %>"></div>
                <div>
                  <div class="task-name"><%= task.topic %></div>
                  <div class="task-subject"><%= task.subject %></div>
                </div>
                <div style="margin-left:auto;text-align:right;">
                  <span class="badge badge-<%= task.priority %>"><%= task.priority %></span>
                  <div class="task-deadline"><%= new Date(task.deadline).toLocaleDateString('en-US', {month:'short',day:'numeric'}) %></div>
                </div>
              </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Upcoming Deadlines -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">⏰ Upcoming Deadlines</div>
          </div>
          <div class="card-body" style="padding-top:8px;padding-bottom:8px;">
            <% if (upcomingDeadlines.length === 0) { %>
              <div style="text-align:center;padding:30px 0;color:var(--text-muted);font-size:13px;">
                🎉 No deadlines in the next 7 days
              </div>
            <% } else { %>
              <% upcomingDeadlines.forEach(task => {
                const daysLeft = Math.ceil((new Date(task.deadline) - new Date()) / (1000*60*60*24));
              %>
              <div class="task-row">
                <div>
                  <div class="task-name" style="font-size:13px;"><%= task.topic %></div>
                  <div class="task-subject"><%= task.subject %></div>
                </div>
                <div style="margin-left:auto;text-align:right;flex-shrink:0;">
                  <div style="font-size:12px;font-weight:700;color:<%= daysLeft <= 1 ? 'var(--red)' : daysLeft <= 3 ? 'var(--amber)' : 'var(--text-secondary)' %>">
                    <%= daysLeft <= 0 ? 'Today!' : daysLeft === 1 ? 'Tomorrow' : `${daysLeft}d left` %>
                  </div>
                </div>
              </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Weekly Plan -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">📅 This Week's AI Plan</div>
          <a href="/planner/ai-schedule" class="btn btn-ghost btn-sm">Full schedule →</a>
        </div>
        <div class="card-body">
          <div class="week-grid">
            <% weeklyPlan.forEach(day => { %>
            <div class="week-day <%= day.isToday ? 'today' : '' %>">
              <div class="week-day-header"><%= day.dayName.substring(0,3) %></div>
              <div class="week-day-date"><%= day.dateStr %></div>
              <% day.tasks.slice(0,3).forEach(task => { %>
                <div class="week-task-pill" title="<%= task.topic %>">
                  <%= task.subject.substring(0,10) %>
                </div>
              <% }) %>
              <% if (day.tasks.length === 0) { %>
                <div style="font-size:10px;color:var(--text-muted);margin-top:8px;">Rest day 😌</div>
              <% } %>
              <div style="font-size:10px;color:var(--text-muted);margin-top:6px;font-family:var(--font-mono);">
                <%= day.allocatedHours %>h
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div><!-- /page-content -->
  </div><!-- /main-content -->
</div>

<script src="/js/app.js"></script>
<script>
// ─── Chart.js Setup ─────────────────────────────────────────────
Chart.defaults.color = '#8892b0';
Chart.defaults.borderColor = '#252a3e';
Chart.defaults.font.family = "'Inter', sans-serif";

// Bar Chart — Weekly hours
const barCtx = document.getElementById('barChart').getContext('2d');
new Chart(barCtx, {
  type: 'bar',
  data: {
    labels: <%- dayLabels %>,
    datasets: [{
      label: 'Study Hours',
      data: <%- weeklyHours %>,
      backgroundColor: 'rgba(108,99,255,0.7)',
      borderColor: '#6c63ff',
      borderWidth: 1,
      borderRadius: 6,
      borderSkipped: false,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
      x: { grid: { color: '#252a3e' } },
      y: { grid: { color: '#252a3e' }, beginAtZero: true, ticks: { stepSize: 1 } }
    }
  }
});

// Pie Chart — Subject distribution
const subjectData = <%- subjectData %>;
const pieCtx = document.getElementById('pieChart').getContext('2d');
const colors = ['#6c63ff','#00d4ff','#00e5a0','#ffb547','#ff4d6d','#9c88ff','#48dbfb'];
new Chart(pieCtx, {
  type: 'doughnut',
  data: {
    labels: subjectData.map(d => d._id || 'Unknown'),
    datasets: [{
      data: subjectData.map(d => d.totalHours),
      backgroundColor: colors.slice(0, subjectData.length),
      borderColor: '#111420',
      borderWidth: 3,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    cutout: '65%',
    plugins: {
      legend: { position: 'right', labels: { padding: 12, boxWidth: 12, font: { size: 11 } } }
    }
  }
});
</script>
</body>
</html>
