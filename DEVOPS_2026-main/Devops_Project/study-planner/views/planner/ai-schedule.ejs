<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'AI Schedule' }) %>
    <%- include('../partials/flash') %>
    <div class="page-content">
      <div class="page-header">
        <div class="page-header-left">
          <h1 class="page-title">✦ AI-Generated Schedule</h1>
          <p class="page-subtitle">Personalized timetable built from your tasks, deadlines & learning profile</p>
        </div>
        <a href="/planner/create" class="btn btn-primary">＋ Add Task</a>
      </div>

      <!-- Rescheduled / Overdue Alert -->
      <% const overdueItems = rescheduled.filter(t => t.isOverdue); %>
      <% if (overdueItems.length > 0) { %>
      <div style="background:rgba(255,77,109,0.08);border:1px solid rgba(255,77,109,0.3);border-radius:var(--radius);padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:14px;">
        <span style="font-size:24px;">🚨</span>
        <div>
          <div style="font-weight:700;color:var(--red);margin-bottom:3px;">
            <%= overdueItems.length %> overdue task<%= overdueItems.length > 1 ? 's' : '' %> detected
          </div>
          <div style="font-size:13px;color:var(--text-secondary);">
            AI has reprioritized these tasks. They appear first in your schedule below.
            <%= overdueItems.map(t => t.topic).join(', ') %>
          </div>
        </div>
        <a href="/planner?status=overdue" class="btn btn-danger btn-sm" style="margin-left:auto;">View Overdue</a>
      </div>
      <% } %>

      <div style="display:grid;grid-template-columns:1fr 320px;gap:24px;align-items:start;">
        <!-- Timetable -->
        <div>
          <% if (timetable.length === 0) { %>
            <div class="empty-state">
              <div class="empty-icon">📅</div>
              <div class="empty-title">No tasks to schedule</div>
              <p class="empty-desc">Add some study tasks and the AI will build your personalized schedule.</p>
              <a href="/planner/create" class="btn btn-primary">＋ Create First Task</a>
            </div>
          <% } else { %>
            <%
              let lastDate = null;
              timetable.forEach((block, i) => {
                const dateStr = new Date(block.date).toDateString();
                const isNewDay = dateStr !== lastDate;
                lastDate = dateStr;
            %>
              <% if (isNewDay) { %>
                <div style="display:flex;align-items:center;gap:12px;margin:<%= i === 0 ? '0' : '24px' %> 0 12px;">
                  <div style="font-family:var(--font-display);font-size:14px;font-weight:700;color:var(--text-primary);">
                    <%= block.dayName %>,
                    <%= new Date(block.date).toLocaleDateString('en-US',{month:'long',day:'numeric'}) %>
                  </div>
                  <div style="flex:1;height:1px;background:var(--border);"></div>
                </div>
              <% } %>

              <div class="timetable-block">
                <div class="d-flex align-center justify-between">
                  <div>
                    <div class="timetable-time">
                      <%= block.startTime %> — <%= block.endTime %>
                      <span style="margin-left:8px;color:var(--text-muted);">(<%= block.duration %>h)</span>
                    </div>
                    <div class="timetable-subject"><%= block.subject %></div>
                    <div class="timetable-meta"><%= block.topic %> &bull; <%= block.type %></div>
                  </div>
                  <div style="text-align:right;">
                    <span class="badge badge-<%= block.priority %>"><%= block.priority %></span>
                    <div style="font-size:11px;color:var(--text-muted);margin-top:6px;font-family:var(--font-mono);">Score: <%= block.aiScore %></div>
                  </div>
                </div>
                <div style="margin-top:8px;font-size:12px;color:var(--accent);display:flex;align-items:center;gap:6px;">
                  💡 <%= block.tips %>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>

        <!-- Sidebar panel -->
        <div>
          <!-- AI Prioritized Task List -->
          <div class="card" style="margin-bottom:16px;">
            <div class="card-header">
              <div class="card-title">✦ AI Priority Queue</div>
            </div>
            <div class="card-body" style="padding-top:8px;padding-bottom:8px;">
              <% if (rescheduled.length === 0) { %>
                <div style="text-align:center;padding:20px 0;font-size:13px;color:var(--text-muted);">
                  🎉 All tasks complete!
                </div>
              <% } else { %>
                <% rescheduled.slice(0,8).forEach((task, idx) => { %>
                <div style="display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);">
                  <div style="font-family:var(--font-mono);font-size:11px;color:var(--text-muted);width:20px;text-align:center;">#<%= idx+1 %></div>
                  <div style="flex:1;min-width:0;">
                    <div style="font-size:13px;font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                      <%= task.topic %>
                    </div>
                    <div style="font-size:11px;color:var(--text-secondary);"><%= task.subject %></div>
                  </div>
                  <div style="text-align:right;flex-shrink:0;">
                    <div style="font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--accent);">
                      <%= task.aiScore %>
                    </div>
                    <% if (task.isOverdue) { %>
                      <span style="font-size:10px;color:var(--red);">OVERDUE</span>
                    <% } %>
                  </div>
                </div>
                <% }) %>
              <% } %>
            </div>
          </div>

          <!-- Legend -->
          <div class="card">
            <div class="card-header"><div class="card-title">📖 Session Types</div></div>
            <div class="card-body" style="font-size:12.5px;color:var(--text-secondary);line-height:2;">
              <div><strong style="color:var(--text-primary);">Introduction</strong> — First encounter with topic</div>
              <div><strong style="color:var(--text-primary);">Core Learning</strong> — Deep understanding phase</div>
              <div><strong style="color:var(--text-primary);">Practice</strong> — Apply concepts with exercises</div>
              <div><strong style="color:var(--text-primary);">Review</strong> — Consolidate knowledge</div>
              <div><strong style="color:var(--text-primary);">Revision</strong> — Spaced repetition before exam</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
