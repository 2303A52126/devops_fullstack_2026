<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Edit Task' }) %>
    <%- include('../partials/flash') %>
    <div class="page-content">
      <div class="page-header">
        <div class="page-header-left">
          <h1 class="page-title">Edit Task</h1>
          <p class="page-subtitle">Update task details — AI score recalculated on save</p>
        </div>
        <a href="/planner/<%= task._id %>" class="btn btn-ghost">← Back</a>
      </div>

      <div class="card" style="max-width:760px;">
        <div class="card-header">
          <div class="card-title">✎ Edit: <%= task.topic %></div>
          <span class="badge badge-<%= task.status %>"><%= task.status %></span>
        </div>
        <div class="card-body">
          <form action="/planner/<%= task._id %>?_method=PUT" method="POST" novalidate>
            <div class="form-grid">
              <div class="form-group">
                <label class="form-label">Subject *</label>
                <input type="text" name="subject" class="form-control" value="<%= task.subject %>" required>
              </div>
              <div class="form-group">
                <label class="form-label">Topic *</label>
                <input type="text" name="topic" class="form-control" value="<%= task.topic %>" required>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Description</label>
              <textarea name="description" class="form-control" maxlength="500"><%= task.description || '' %></textarea>
            </div>

            <div class="form-grid-3">
              <div class="form-group">
                <label class="form-label">Deadline *</label>
                <input type="date" name="deadline" class="form-control" required
                  value="<%= new Date(task.deadline).toISOString().split('T')[0] %>">
              </div>
              <div class="form-group">
                <label class="form-label">Est. Hours</label>
                <input type="number" name="estimatedHours" class="form-control" step="0.5"
                  value="<%= task.estimatedHours %>">
              </div>
              <div class="form-group">
                <label class="form-label">Actual Hours</label>
                <input type="number" name="actualHours" class="form-control" step="0.5"
                  value="<%= task.actualHours || 0 %>">
              </div>
            </div>

            <div class="form-grid-3">
              <div class="form-group">
                <label class="form-label">Priority</label>
                <select name="priority" class="form-control">
                  <% ['low','medium','high','critical'].forEach(p => { %>
                    <option value="<%= p %>" <%= task.priority === p ? 'selected' : '' %>><%= p.charAt(0).toUpperCase()+p.slice(1) %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Difficulty</label>
                <select name="difficulty" class="form-control">
                  <% ['easy','medium','hard','expert'].forEach(d => { %>
                    <option value="<%= d %>" <%= task.difficulty === d ? 'selected' : '' %>><%= d.charAt(0).toUpperCase()+d.slice(1) %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Status</label>
                <select name="status" class="form-control">
                  <% ['pending','in-progress','completed','overdue'].forEach(s => { %>
                    <option value="<%= s %>" <%= task.status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase()+s.slice(1).replace('-',' ') %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Tags</label>
              <input type="text" name="tags" class="form-control"
                value="<%= (task.tags || []).join(', ') %>" placeholder="tag1, tag2">
            </div>

            <div class="form-group">
              <label class="form-label">Notes</label>
              <textarea name="notes" class="form-control" maxlength="1000" style="min-height:80px;"><%= task.notes || '' %></textarea>
            </div>

            <div class="d-flex gap-12">
              <button type="submit" class="btn btn-primary">Save Changes</button>
              <a href="/planner/<%= task._id %>" class="btn btn-ghost">Cancel</a>
              <form action="/planner/<%= task._id %>?_method=DELETE" method="POST" style="margin-left:auto;">
                <button type="submit" class="btn btn-danger"
                  data-confirm="Permanently delete this task?">Delete Task</button>
              </form>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
